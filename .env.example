# App
ADDR=:8080
WEB_DIR=/app/web
LOG_LEVEL=info

# GitHub profile/repos
GITHUB_USER=ghassenelkamel
# GITHUB_TOKEN=

# Dynamic content repo
CONTENT_REPO_OWNER=ghassenelkamel
CONTENT_REPO_NAME=portfolio-content
CONTENT_REPO_REF=main
CONTENT_REPO_DIR=content
CONTENT_CACHE_TTL=300

# Contact delivery: SMTP (preferred)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@example.com
SMTP_TO=you@example.com
SMTP_REQUIRE_TLS=true

# Contact delivery fallback: webhook forwarder (optional)
# CONTACT_FORWARD_URL=https://your-webhook-endpoint.example.com/contact

# Frontend proxy (dev)
VITE_API_PROXY_TARGET=http://api:8080
